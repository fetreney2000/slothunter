    "@types/jsonwebtoken": "^9.0.10",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "type": "module",
  "dependencies": {
    "@skeletonlabs/skeleton": "^4.15.2",
    "@skeletonlabs/skeleton-svelte": "^4.15.2",
    "@tailwindcss/vite": "^4.0.0",
    "@vite-pwa/sveltekit": "^0.6.0",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.0.0",
